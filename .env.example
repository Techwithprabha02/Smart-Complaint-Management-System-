# Server
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/smart-complaints
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Production (Render) — your Vercel app URL, no trailing slash
# Multiple preview URLs: https://app.vercel.app,https://preview.vercel.app
CLIENT_URL=http://localhost:5173

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Client (for frontend — copy to client/.env)
VITE_API_BASE_URL=http://localhost:5000/api
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key
